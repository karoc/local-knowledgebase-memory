{
  "id": "openclaw-memory-local-mysql",
  "name": "记忆插件 (本地 MySQL)",
  "description": "基于自建 MySQL + Ollama 的长期记忆插件",
  "kind": "memory",
  "configSchema": {
    "type": "object",
    "required": ["mysql", "ollama"],
    "properties": {
      "mysql": { "type": "object", "required": ["host", "user", "password", "database"], "properties": { "host": { "type": "string" }, "port": { "type": "number" }, "user": { "type": "string" }, "password": { "type": "string" }, "database": { "type": "string" } } },
      "ollama": { "type": "object", "required": ["baseUrl", "model"], "properties": { "baseUrl": { "type": "string" }, "model": { "type": "string" }, "dimensions": { "type": "number" } } },
      "autoRecall": { "type": "boolean", "default": true },
      "autoCapture": { "type": "boolean", "default": true },
      "minRecallScore": { "type": "number", "default": 0.3 }
    }
  }
}